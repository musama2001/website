# Frontend
# Next.js will use its own .env.local -> see frontend/.env.local.example

# Server
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/pivotpulse?retryWrites=true&w=majority
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
OPENAI_API_KEY=sk-your-openai-key

# SMTP for contact notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=yourpassword
SMTP_FROM=no-reply@pivotpulse.com
NOTIFY_EMAIL=notify@pivotpulse.com
